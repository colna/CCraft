{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevChat",
  "version": "0.1.0",
  "identifier": "app.devchat.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "DevChat",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "callback",
          "pathPrefix": ["/github"]
        }
      ],
      "desktop": {
        "schemes": ["devchat"]
      }
    }
  }
}
