{
  "identifier": "default",
  "description": "Default permissions for DevChat",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://api.github.com/**" },
        { "url": "https://*.openai.com/**" },
        { "url": "https://api.anthropic.com/**" },
        { "url": "http://172.245.240.135:8080/**" }
      ]
    }
  ]
}
